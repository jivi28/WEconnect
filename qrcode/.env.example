# Copy to `.env` and fill in. Vite only exposes vars prefixed with VITE_.

# Supabase project URL + publishable (anon) key — safe to ship to the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: base URL the QR code points at, so a phone can reach the register page.
# Leave unset to use the current browser origin. Examples:
#   VITE_PUBLIC_BASE_URL=http://192.168.1.50:5173   (your LAN IP, same Wi-Fi)
#   VITE_PUBLIC_BASE_URL=https://your-tunnel.example.dev
# VITE_PUBLIC_BASE_URL=
