# Supabase project credentials (https://app.supabase.com -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the browser. Used by API routes + seed/scrape scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Contact email used in the Nominatim geocoder User-Agent (required by their usage policy)
GEOCODER_CONTACT_EMAIL=you@example.com
